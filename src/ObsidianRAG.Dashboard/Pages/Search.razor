@page "/search"
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>向量搜索 - Obsidian RAG</PageTitle>

<div class="page-container">
    <header class="page-header">
        <h1>🔍 向量搜索</h1>
    </header>

    <!-- 搜索框 -->
    <div class="search-box">
        <div class="search-input-wrapper">
            <input type="text" @bind="query" @bind:event="oninput" placeholder="输入搜索内容..." class="search-input" @onkeypress="OnKeyPress" />
            <button class="btn btn-primary search-btn" @onclick="ExecuteSearch" disabled="@string.IsNullOrEmpty(query) || isSearching">
                @if (isSearching)
                {
                    <span>⏳ 搜索中...</span>
                }
                else
                {
                    <span>🔍 搜索</span>
                }
            </button>
        </div>

        <!-- 搜索选项 -->
        <div class="search-options">
            <div class="option-group">
                <label>查询模式</label>
                <select @bind="searchMode" class="form-control-sm">
                    <option value="Quick">快速 (~1000 tokens)</option>
                    <option value="Standard">标准 (~3000 tokens)</option>
                    <option value="Deep">深度 (~6000 tokens)</option>
                </select>
            </div>
            <div class="option-group">
                <label>返回数量</label>
                <input type="number" @bind="topK" min="1" max="50" class="form-control-sm" />
            </div>
            <div class="option-group">
                <label>限定源</label>
                <select @bind="selectedSource" class="form-control-sm">
                    <option value="">全部</option>
                    @if (sources != null)
                    {
                        @foreach (var source in sources)
                        {
                            <option value="@source.Name">@source.Name</option>
                        }
                    }
                </select>
            </div>
        </div>
    </div>

    <!-- 搜索结果 -->
    @if (results != null)
    {
        <div class="search-results">
            <div class="results-header">
                <span>找到 @results.Chunks.Count 个结果</span>
                <span class="query-time">耗时 @results.Stats.DurationMs ms</span>
            </div>

            @if (results.Chunks.Count == 0)
            {
                <div class="empty-state">
                    <p>未找到相关内容</p>
                </div>
            }
            else
            {
                @foreach (var chunk in results.Chunks)
                {
                    <div class="result-card">
                        <div class="result-header">
                            <span class="result-score">相似度: @chunk.Score.ToString("F4")</span>
                            <span class="result-source">@chunk.Source</span>
                        </div>
                        <h4 class="result-title">@chunk.Title</h4>
                        <div class="result-meta">
                            <span class="result-file">📄 @chunk.FilePath</span>
                            @if (!string.IsNullOrEmpty(chunk.HeadingPath))
                            {
                                <span class="result-heading">📍 @chunk.HeadingPath</span>
                            }
                            <span class="result-lines">行 @chunk.StartLine-@chunk.EndLine</span>
                        </div>
                        <div class="result-content">
                            @chunk.Content
                        </div>
                        <div class="result-actions">
                            <button class="btn btn-sm btn-secondary" @onclick="() => CopyLink(chunk)">📋 复制链接</button>
                            <button class="btn btn-sm btn-secondary" @onclick="() => DrillDown(chunk)">📖 展开上下文</button>
                        </div>
                    </div>
                }
            }

            @if (!string.IsNullOrEmpty(results.Suggestion))
            {
                <div class="suggestion">
                    💡 @results.Suggestion
                </div>
            }
        </div>
    }

    <!-- 搜索历史 -->
    <div class="search-history">
        <h3>搜索历史</h3>
        @if (searchHistory.Count == 0)
        {
            <p class="empty-state">暂无搜索记录</p>
        }
        else
        {
            <div class="history-list">
                @foreach (var item in searchHistory.Take(10))
                {
                    <div class="history-item" @onclick="() => UseHistory(item)">
                        <span class="history-query">@item.Query</span>
                        <span class="history-time">@item.Time.ToString("HH:mm")</span>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private string query = "";
    private string searchMode = "Standard";
    private int topK = 10;
    private string selectedSource = "";
    private bool isSearching;
    private SearchResponse? results;
    private List<SourceInfo>? sources;
    private List<SearchHistoryItem> searchHistory = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadSources();
    }

    private async Task LoadSources()
    {
        try
        {
            sources = await Http.GetFromJsonAsync<List<SourceInfo>>("/api/dashboard/sources");
        }
        catch
        {
            sources = new List<SourceInfo>
            {
                new SourceInfo { Name = "测试笔记库" }
            };
        }
    }

    private async Task OnKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ExecuteSearch();
        }
    }

    private async Task ExecuteSearch()
    {
        if (string.IsNullOrEmpty(query)) return;

        isSearching = true;
        
        try
        {
            var request = new SearchRequest
            {
                Query = query,
                Mode = searchMode,
                TopK = topK,
                Sources = string.IsNullOrEmpty(selectedSource) ? null : new List<string> { selectedSource }
            };

            var response = await Http.PostAsJsonAsync("/api/ai/query", request);
            
            if (response.IsSuccessStatusCode)
            {
                results = await response.Content.ReadFromJsonAsync<SearchResponse>();
            }
            else
            {
                // 模拟数据
                results = new SearchResponse
                {
                    Query = query,
                    Chunks = new List<ChunkResult>
                    {
                        new ChunkResult
                        {
                            Title = "配置说明",
                            FilePath = "test-vault/README.md",
                            Content = "配置文件位于 `obsidian-rag.json`。支持多个源文件夹配置...",
                            Score = 0.85f,
                            Source = "测试笔记库",
                            StartLine = 10,
                            EndLine = 20
                        }
                    },
                    Stats = new SearchStats { DurationMs = 25 }
                };
            }

            // 添加到历史
            searchHistory.Insert(0, new SearchHistoryItem { Query = query, Time = DateTime.Now });
            if (searchHistory.Count > 20) searchHistory.RemoveAt(searchHistory.Count - 1);
        }
        finally
        {
            isSearching = false;
        }
    }

    private void UseHistory(SearchHistoryItem item)
    {
        query = item.Query;
    }

    private void CopyLink(ChunkResult chunk)
    {
        // 复制 Obsidian 链接到剪贴板
        // TODO: 实现 JS 互操作
    }

    private async Task DrillDown(ChunkResult chunk)
    {
        // 展开上下文
        // TODO: 调用 drill-down API
    }

    public class SourceInfo
    {
        public string Name { get; set; } = "";
    }

    public class SearchRequest
    {
        public string Query { get; set; } = "";
        public string Mode { get; set; } = "standard";
        public int TopK { get; set; } = 10;
        public List<string>? Sources { get; set; }
    }

    public class SearchResponse
    {
        public string Query { get; set; } = "";
        public List<ChunkResult> Chunks { get; set; } = new();
        public SearchStats Stats { get; set; } = new();
        public string? Suggestion { get; set; }
    }

    public class ChunkResult
    {
        public string Title { get; set; } = "";
        public string FilePath { get; set; } = "";
        public string Content { get; set; } = "";
        public float Score { get; set; }
        public string? Source { get; set; }
        public string? HeadingPath { get; set; }
        public int StartLine { get; set; }
        public int EndLine { get; set; }
    }

    public class SearchStats
    {
        public long DurationMs { get; set; }
    }

    public class SearchHistoryItem
    {
        public string Query { get; set; } = "";
        public DateTime Time { get; set; }
    }
}
