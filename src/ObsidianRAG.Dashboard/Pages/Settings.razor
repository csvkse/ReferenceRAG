@page "/settings"
@inject HttpClient Http
@inject NavigationManager NavManager

<PageTitle>设置 - Obsidian RAG</PageTitle>

<div class="page-container">
    <header class="page-header">
        <h1>⚙️ 系统设置</h1>
    </header>

    <div class="settings-grid">
        <!-- 模型设置 -->
        <div class="settings-card">
            <h2>🤖 向量模型</h2>
            <div class="form-group">
                <label>模型路径</label>
                <input type="text" @bind="modelPath" class="form-control" />
            </div>
            <div class="form-group">
                <label>模型名称</label>
                <input type="text" @bind="modelName" class="form-control" />
            </div>
            <div class="form-group">
                <label>最大序列长度</label>
                <input type="number" @bind="maxSequenceLength" class="form-control" />
            </div>
            <div class="form-group">
                <label>批处理大小</label>
                <input type="number" @bind="batchSize" class="form-control" />
            </div>
            <div class="form-group">
                <label>
                    <input type="checkbox" @bind="useCuda" /> 使用 CUDA 加速
                </label>
            </div>
        </div>

        <!-- 分段设置 -->
        <div class="settings-card">
            <h2>📄 分段配置</h2>
            <div class="form-group">
                <label>最大 Token 数</label>
                <input type="number" @bind="maxTokens" class="form-control" />
            </div>
            <div class="form-group">
                <label>最小 Token 数</label>
                <input type="number" @bind="minTokens" class="form-control" />
            </div>
            <div class="form-group">
                <label>重叠 Token 数</label>
                <input type="number" @bind="overlapTokens" class="form-control" />
            </div>
            <div class="form-group">
                <label>
                    <input type="checkbox" @bind="preserveHeadings" /> 保留标题结构
                </label>
            </div>
            <div class="form-group">
                <label>
                    <input type="checkbox" @bind="preserveCodeBlocks" /> 保留代码块
                </label>
            </div>
        </div>

        <!-- 搜索设置 -->
        <div class="settings-card">
            <h2>🔍 搜索配置</h2>
            <div class="form-group">
                <label>默认返回数量</label>
                <input type="number" @bind="defaultTopK" class="form-control" />
            </div>
            <div class="form-group">
                <label>相似度阈值</label>
                <input type="number" step="0.1" @bind="similarityThreshold" class="form-control" />
            </div>
            <div class="form-group">
                <label>
                    <input type="checkbox" @bind="enableMmr" /> 启用 MMR 多样性
                </label>
            </div>
            <div class="form-group">
                <label>MMR Lambda</label>
                <input type="number" step="0.1" @bind="mmrLambda" class="form-control" />
            </div>
        </div>

        <!-- 服务设置 -->
        <div class="settings-card">
            <h2>🌐 服务配置</h2>
            <div class="form-group">
                <label>监听端口</label>
                <input type="number" @bind="port" class="form-control" />
            </div>
            <div class="form-group">
                <label>监听地址</label>
                <input type="text" @bind="host" class="form-control" />
            </div>
            <div class="form-group">
                <label>
                    <input type="checkbox" @bind="enableCors" /> 启用 CORS
                </label>
            </div>
            <div class="form-group">
                <label>
                    <input type="checkbox" @bind="enableSwagger" /> 启用 Swagger
                </label>
            </div>
            <div class="form-group">
                <label>日志级别</label>
                <select @bind="logLevel" class="form-control">
                    <option value="Trace">Trace</option>
                    <option value="Debug">Debug</option>
                    <option value="Information">Information</option>
                    <option value="Warning">Warning</option>
                    <option value="Error">Error</option>
                </select>
            </div>
        </div>

        <!-- 自动索引设置 -->
        <div class="settings-card">
            <h2>🔄 自动索引</h2>
            <div class="form-group">
                <label>
                    <input type="checkbox" @bind="autoIndexEnabled" /> 启用自动索引
                </label>
            </div>
            <div class="form-group">
                <label>索引间隔（分钟）</label>
                <input type="number" @bind="autoIndexInterval" class="form-control" />
            </div>
            <div class="form-group">
                <label>索引线程数</label>
                <input type="number" @bind="indexThreads" min="1" max="8" class="form-control" />
            </div>
            <div class="form-group">
                <label>
                    <input type="checkbox" @bind="watchForChanges" /> 监控文件变化
                </label>
            </div>
        </div>

        <!-- 数据管理 -->
        <div class="settings-card">
            <h2>💾 数据管理</h2>
            <div class="form-group">
                <label>数据存储路径</label>
                <input type="text" @bind="dataPath" class="form-control" />
            </div>
            <div class="form-group">
                <button class="btn btn-secondary" @onclick="ClearIndex">🗑️ 清理索引数据</button>
            </div>
            <div class="form-group">
                <button class="btn btn-secondary" @onclick="ExportConfig">📤 导出配置</button>
                <button class="btn btn-secondary" @onclick="ImportConfig">📥 导入配置</button>
            </div>
        </div>
    </div>

    <div class="settings-actions">
        <button class="btn btn-primary" @onclick="SaveSettings">💾 保存设置</button>
        <button class="btn btn-secondary" @onclick="ResetSettings">↩️ 重置默认</button>
    </div>
</div>

@code {
    // 模型设置
    private string modelPath = "models/bge-small-zh-v1.5/model.onnx";
    private string modelName = "bge-small-zh-v1.5";
    private int maxSequenceLength = 512;
    private int batchSize = 32;
    private bool useCuda;

    // 分段设置
    private int maxTokens = 512;
    private int minTokens = 50;
    private int overlapTokens = 50;
    private bool preserveHeadings = true;
    private bool preserveCodeBlocks = true;

    // 搜索设置
    private int defaultTopK = 10;
    private float similarityThreshold = 0.5f;
    private bool enableMmr = true;
    private float mmrLambda = 0.7f;

    // 服务设置
    private int port = 5000;
    private string host = "localhost";
    private bool enableCors = true;
    private bool enableSwagger = true;
    private string logLevel = "Information";

    // 自动索引
    private bool autoIndexEnabled;
    private int autoIndexInterval = 60;
    private int indexThreads = 2;
    private bool watchForChanges = true;

    // 数据路径
    private string dataPath = "data";

    protected override async Task OnInitializedAsync()
    {
        await LoadConfig();
    }

    private async Task LoadConfig()
    {
        try
        {
            config = await Http.GetFromJsonAsync<AppConfig>("/api/settings");
            if (config != null)
            {
                modelPath = config.Embedding.ModelPath;
                modelName = config.Embedding.ModelName;
                maxSequenceLength = config.Embedding.MaxSequenceLength;
                batchSize = config.Embedding.BatchSize;
                useCuda = config.Embedding.UseCuda;
                
                maxTokens = config.Chunking.MaxTokens;
                minTokens = config.Chunking.MinTokens;
                overlapTokens = config.Chunking.OverlapTokens;
                preserveHeadings = config.Chunking.PreserveHeadings;
                preserveCodeBlocks = config.Chunking.PreserveCodeBlocks;
                
                defaultTopK = config.Search.DefaultTopK;
                similarityThreshold = config.Search.SimilarityThreshold;
                enableMmr = config.Search.EnableMmr;
                mmrLambda = config.Search.MmrLambda;
                
                port = config.Service.Port;
                host = config.Service.Host;
                enableCors = config.Service.EnableCors;
                enableSwagger = config.Service.EnableSwagger;
                logLevel = config.Service.LogLevel;
                
                dataPath = config.DataPath;
            }
        }
        catch
        {
            // 使用默认值
        }
    }

    private async Task SaveSettings()
    {
        try
        {
            var config = new AppConfig
            {
                DataPath = dataPath,
                Embedding = new EmbeddingConfig
                {
                    ModelPath = modelPath,
                    ModelName = modelName,
                    MaxSequenceLength = maxSequenceLength,
                    BatchSize = batchSize,
                    UseCuda = useCuda
                },
                Chunking = new ChunkingConfig
                {
                    MaxTokens = maxTokens,
                    MinTokens = minTokens,
                    OverlapTokens = overlapTokens,
                    PreserveHeadings = preserveHeadings,
                    PreserveCodeBlocks = preserveCodeBlocks
                },
                Search = new SearchConfig
                {
                    DefaultTopK = defaultTopK,
                    SimilarityThreshold = similarityThreshold,
                    EnableMmr = enableMmr,
                    MmrLambda = mmrLambda
                },
                Service = new ServiceConfig
                {
                    Port = port,
                    Host = host,
                    EnableCors = enableCors,
                    EnableSwagger = enableSwagger,
                    LogLevel = logLevel
                }
            };
            
            await Http.PostAsJsonAsync("/api/settings", config);
        }
        catch
        {
            // TODO: 显示错误
        }
    }

    private async Task ResetSettings()
    {
        await LoadConfig();
    }

    private async Task ClearIndex()
    {
        // TODO: 调用清理 API
    }

    private async Task ExportConfig()
    {
        // TODO: 导出配置为 JSON
    }

    private async Task ImportConfig()
    {
        // TODO: 从文件导入配置
    }

    private AppConfig? config;

    public class AppConfig
    {
        public string DataPath { get; set; } = "data";
        public EmbeddingConfig Embedding { get; set; } = new();
        public ChunkingConfig Chunking { get; set; } = new();
        public SearchConfig Search { get; set; } = new();
        public ServiceConfig Service { get; set; } = new();
    }

    public class EmbeddingConfig
    {
        public string ModelPath { get; set; } = "";
        public string ModelName { get; set; } = "";
        public int MaxSequenceLength { get; set; }
        public int BatchSize { get; set; }
        public bool UseCuda { get; set; }
    }

    public class ChunkingConfig
    {
        public int MaxTokens { get; set; }
        public int MinTokens { get; set; }
        public int OverlapTokens { get; set; }
        public bool PreserveHeadings { get; set; }
        public bool PreserveCodeBlocks { get; set; }
    }

    public class SearchConfig
    {
        public int DefaultTopK { get; set; }
        public float SimilarityThreshold { get; set; }
        public bool EnableMmr { get; set; }
        public float MmrLambda { get; set; }
    }

    public class ServiceConfig
    {
        public int Port { get; set; }
        public string Host { get; set; } = "";
        public bool EnableCors { get; set; }
        public bool EnableSwagger { get; set; }
        public string LogLevel { get; set; } = "";
    }
}
