<?xml version="1.0" encoding="utf-8"?>
<!--
  ReferenceRAG.Desktop win-x64 发布配置

  模式：Framework-Dependent（推荐）
  - 输出目录较小（~50MB vs ~200MB self-contained）
  - 目标机器需安装 .NET 10 Windows Desktop Runtime
  - 下载地址：https://dotnet.microsoft.com/download/dotnet/10.0

  如需 Self-Contained（无需预装 .NET），将 SelfContained 改为 true。
  注意：Self-Contained + PublishSingleFile + WebView2 会生成解压临时目录，见注释。
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishDir>$(MSBuildThisFileDirectory)..\..\..\..\publish\desktop</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>

    <!-- 托管程序集合并进单个 exe -->
    <PublishSingleFile>true</PublishSingleFile>

    <!--
      保持 false：原生库（WebView2Loader.dll、onnxruntime*.dll）留在 exe 旁边。
      WebView2 要求 WebView2Loader.dll 必须与 exe 同目录，提取到 %TEMP% 会导致闪退。
    -->
    <IncludeNativeLibrariesForSelfExtract>false</IncludeNativeLibrariesForSelfExtract>

    <!-- 发布时自动运行 ReadyToRun 预编译（加快启动速度） -->
    <PublishReadyToRun>true</PublishReadyToRun>

    <!-- 裁剪：WPF + WebView2 不兼容激进裁剪，保持禁用 -->
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>