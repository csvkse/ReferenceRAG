<?xml version="1.0" encoding="utf-8"?>
<!--
  ReferenceRAG.Desktop win-x64 发布配置

  模式：Framework-Dependent（推荐）
  - 输出目录较小（~50MB vs ~200MB self-contained）
  - 目标机器需安装 .NET 10 Windows Desktop Runtime
  - 下载地址：https://dotnet.microsoft.com/download/dotnet/10.0

  如需 Self-Contained（无需预装 .NET），将 SelfContained 改为 true。
  注意：Self-Contained + PublishSingleFile + WebView2 会生成解压临时目录，见注释。
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishDir>$(MSBuildThisFileDirectory)..\..\..\..\publish\desktop</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>

    <!--
      PublishSingleFile：将托管程序集合并为单个 exe。
      注意：WebView2Loader.dll 是原生库，无法真正内嵌。
      即使 PublishSingleFile=true，运行时仍会解压到临时目录。
      设为 false 可得到干净的文件夹输出，无临时目录副作用。
    -->
    <PublishSingleFile>false</PublishSingleFile>

    <!--
      true 时将原生库（WebView2Loader.dll 等）打包进 exe，
      运行时解压到 %TEMP%。仅在 PublishSingleFile=true 时有意义。
    -->
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>

    <!-- 发布时自动运行 ReadyToRun 预编译（加快启动速度） -->
    <PublishReadyToRun>true</PublishReadyToRun>

    <!-- 裁剪：WPF + WebView2 不兼容激进裁剪，保持禁用 -->
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>